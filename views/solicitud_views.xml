<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de Búsqueda -->
    <record id="view_solicitud_interna_search" model="ir.ui.view">
        <field name="name">solicitud.interna.search</field>
        <field name="model">solicitud.interna</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="solicitante_id"/>
                <field name="asignada_id"/>
                <field name="titulo"/>
                <separator/>
                <filter string="Borrador" name="borrador" domain="[('state','=','borrador')]"/>
                <filter string="Finalizadas" name="finalizada" domain="[('state','=','finalizada')]"/>
                <group>
                    <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Vista Kanban -->
    <record id="view_solicitud_interna_kanban" model="ir.ui.view">
        <field name="name">solicitud.interna.kanban</field>
        <field name="model">solicitud.interna</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong><field name="name"/></strong>
                                <div><field name="titulo"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vista List (ANTIGUA TREE) -->
    <record id="view_solicitud_interna_tree" model="ir.ui.view">
        <field name="name">solicitud.interna.list</field>
        <field name="model">solicitud.interna</field>
        <field name="arch" type="xml">
            <list default_order="fecha_solicitud desc">
                <field name="name"/>
                <field name="titulo"/>
                <field name="state" widget="badge"/>
                <field name="solicitante_id"/>
            </list>
        </field>
    </record>

    <!-- Vista Form -->
    <record id="view_solicitud_interna_form" model="ir.ui.view">
        <field name="name">solicitud.interna.form</field>
        <field name="model">solicitud.interna</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_enviar" string="Enviar" type="object" class="oe_highlight" invisible="state != 'borrador'"/>
                    <button name="action_finalizar" string="Finalizar" type="object" class="oe_highlight" invisible="state == 'finalizada'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="titulo"/>
                            <field name="solicitante_id"/>
                        </group>
                        <group>
                            <field name="fecha_solicitud"/>
                            <field name="prioridad"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descripción">
                            <field name="descripcion"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
